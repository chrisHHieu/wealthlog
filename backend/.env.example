# WealthLog Backend — copy to .env and fill in values

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://wealthlog:changeme@localhost:5433/wealthlog
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20

# ── CORS ───────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3001"]

# ── App ────────────────────────────────────────────────────────────────────────
APP_DEBUG=false
# APP_NAME=WealthLog API

# ── AI Provider ────────────────────────────────────────────────────────────────
# Anthropic (default)
ANTHROPIC_API_KEY=sk-ant-api03-...
# DeepSeek key (optional) — điền để DeepSeek models xuất hiện trong UI model picker
# DEEPSEEK_API_KEY=sk-...

# ── Agent model (startup default — có thể thay đổi từ UI chat panel) ──────────
# Anthropic options : claude-sonnet-4-6 | claude-haiku-4-5-20251001
# DeepSeek options  : deepseek-v4-pro   | deepseek-v4-flash
# Lưu ý: khi user chọn model ở UI, tất cả AI features đều dùng model đó (lưu vào DB).
# AGENT_MODEL ở đây chỉ là fallback khi chưa có lựa chọn nào trong DB.
AGENT_MODEL=claude-sonnet-4-6
AGENT_MAX_TOKENS=8000

# Extended thinking (set to false nếu model không hỗ trợ, e.g. Haiku)
AGENT_THINKING_ENABLED=true
AGENT_THINKING_BUDGET=8000

# ── Short-term memory (context window) ────────────────────────────────────────
# AGENT_MAX_TURNS_IN_CONTEXT=20
# AGENT_KEEP_RECENT_TURNS=3
# AGENT_TOOL_RESULT_MAX_CHARS=3000
# AGENT_OLD_TURN_TOOL_RESULT_CHARS=600
# AGENT_RECENT_TURN_MAX_CHARS=20000
# AGENT_MAX_INPUT_TOKENS=150000

# ── Long-term memory — fact extraction ────────────────────────────────────────
# AGENT_REVIEW_CADENCE=6
# USER_FACT_DEFAULT_CONTEXT_TTL_DAYS=90
# USER_FACT_DEDUP_SIMILARITY_THRESHOLD=0.85
# USER_FACT_CONSOLIDATION_THRESHOLD=100

# ── Long-term memory — session summaries ──────────────────────────────────────
# SESSION_SUMMARY_IDLE_MINUTES=30
# SESSION_SUMMARY_MAX_RECENT=5
# SESSION_SUMMARY_TOPIC_HITS=2

# ── Long-term memory — user model synthesis ───────────────────────────────────
# USER_MODEL_SYNTHESIS_CADENCE=5
# USER_MODEL_FACT_DELTA_THRESHOLD=5
# USER_MODEL_MAX_VERSIONS=3

# ── MCP server (external clients, thường không cần đổi) ───────────────────────
# MCP_HOST=0.0.0.0
# MCP_PORT=8002
