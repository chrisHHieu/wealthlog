# WealthLog Backend — copy to .env and fill in values
# Used when running backend locally (outside Docker)

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://wealthlog:changeme@localhost:5433/wealthlog

# Connection pool (optional — defaults shown)
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3001"]

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=true
# APP_NAME=WealthLog API
# API_PREFIX=/api

# ── AI Agent ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...        # required
AGENT_MODEL=claude-haiku-4-5-20251001
AGENT_MAX_TOKENS=4096
# AGENT_TOOL_RESULT_MAX_CHARS=3000   # max chars per tool result before truncation
# AGENT_MAX_HISTORY_TOKENS=16000     # token budget for conversation history
# AGENT_REVIEW_MODEL=claude-haiku-4-5-20251001  # model for background memory review
# AGENT_REVIEW_CADENCE=6             # review every N turns per session

# ── MCP (optional — defaults work for in-process usage) ──────────────────────
# MCP_HOST=0.0.0.0
# MCP_PORT=8002
# MCP_SERVER_URL=http://localhost:8002/sse
