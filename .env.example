# WealthLog — Root .env for Docker Compose
# Copy to .env and fill in values before running: docker compose up

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=wealthlog
POSTGRES_PASSWORD=changeme           # change this!
POSTGRES_DB=wealthlog

# ── App ───────────────────────────────────────────────────────────────────────
APP_DEBUG=false

# ── AI Agent ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...   # required — get from console.anthropic.com
AGENT_MODEL=claude-haiku-4-5-20251001
AGENT_MAX_TOKENS=4096
# AGENT_TOOL_RESULT_MAX_CHARS=3000
# AGENT_MAX_HISTORY_TOKENS=16000
# AGENT_REVIEW_MODEL=claude-haiku-4-5-20251001
# AGENT_REVIEW_CADENCE=6
# AGENT_THINKING_ENABLED=true
# AGENT_THINKING_BUDGET=2000

# ── MCP (optional — defaults work) ───────────────────────────────────────────
# MCP_HOST=0.0.0.0
# MCP_PORT=8002
