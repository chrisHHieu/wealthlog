# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ===================================
# Node / Frontend
# ===================================
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Next.js
.next/
out/
build/
dist/

# Typescript
*.tsbuildinfo
next-env.d.ts

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Testing
coverage/

# Vercel
.vercel

# ===================================
# Python / Backend
# ===================================
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg

# Virtual Environments
.venv/
venv/
env/

# Testing/Cache
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.ruff_cache/
.mypy_cache/

# ===================================
# Database & Backup
# ===================================
*.db
*.db.bak
backup/*.sql
backup/*.dump
backup/daily/
backup/last/
backup/monthly/
backup/weekly/

# ===================================
# Environment Variables
# ===================================
.env*
!.env.example

# ===================================
# IDE & Editors
# ===================================
.vscode/
.idea/
.claude/
*.swp
*.swo

# ===================================
# OS & Misc
# ===================================
.DS_Store
Thumbs.db
*.pem
*.log
